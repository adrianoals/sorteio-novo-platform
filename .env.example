# Copie este arquivo para .env e preencha os valores.
# Nunca commite .env no repositório.

# --- Banco (PostgreSQL) ---
# Local (Docker): postgresql://postgres:postgres@localhost:5432/sorteionovo (ver docker-compose.yml)
# Produção (Supabase): connection string do projeto no dashboard Supabase
DATABASE_URL=

# --- Auth (Admin — NextAuth ou equivalente) ---
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=
# Em dev: http://localhost:3000
# Em produção: https://seu-dominio.vercel.app (configurar depois)
NEXTAUTH_URL=http://localhost:3000
